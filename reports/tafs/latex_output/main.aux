\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Mean attention mass assigned by TAFS to three feature groups on the synthetic regime-switch task. The regime change at $t{=}200$ moves the informative subset from $\{\text  {lag-1},\text  {roll-7}\}$ (regime A) to $\{\text  {exog-1},\text  {exog-2}\}$ (regime B); TAFS re-allocates its attention within a small number of steps, while nuisance features remain suppressed.}}{5}{figure.2}\protected@file@percent }
\newlabel{fig:synth_regime}{{2}{5}{Mean attention mass assigned by TAFS to three feature groups on the synthetic regime-switch task. The regime change at $t{=}200$ moves the informative subset from $\{\text {lag-1},\text {roll-7}\}$ (regime A) to $\{\text {exog-1},\text {exog-2}\}$ (regime B); TAFS re-allocates its attention within a small number of steps, while nuisance features remain suppressed}{figure.2}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Per-step attention map averaged across heads on the synthetic regime-switch task. Each row is one of $p{=}32$ engineered features (top: lag/rolling; middle: exogenous; bottom: nuisance). The boundary at $t{=}200$ is clearly visible.}}{5}{figure.3}\protected@file@percent }
\newlabel{fig:attn_heatmap}{{3}{5}{Per-step attention map averaged across heads on the synthetic regime-switch task. Each row is one of $p{=}32$ engineered features (top: lag/rolling; middle: exogenous; bottom: nuisance). The boundary at $t{=}200$ is clearly visible}{figure.3}{}}
