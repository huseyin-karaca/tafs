\@writefile{lot}{\contentsline {table}{\numberline {III}{\ignorespaces Main results on the seven real-world datasets. We report MASE; lower is better. Values are means over five random seeds. The best non-oracle score per column is in \textbf  {bold}; the second best is \underline  {underlined}. The oracle row reports a per-step best-base-predictor upper bound and is not in competition.}}{6}{table.3}\protected@file@percent }
\newlabel{tab:main_results}{{III}{6}{Main results on the seven real-world datasets. We report MASE; lower is better. Values are means over five random seeds. The best non-oracle score per column is in \textbf {bold}; the second best is \underline {underlined}. The oracle row reports a per-step best-base-predictor upper bound and is not in competition}{table.3}{}}
\@writefile{lot}{\contentsline {table}{\numberline {IV}{\ignorespaces sMAPE (\%, $\downarrow $) on the seven real-world datasets averaged across five seeds. Only the representative competitors are shown; the trend mirrors Table~\ref {tab:main_results}.}}{6}{table.4}\protected@file@percent }
\newlabel{tab:smape}{{IV}{6}{sMAPE (\%, $\downarrow $) on the seven real-world datasets averaged across five seeds. Only the representative competitors are shown; the trend mirrors Table~\ref {tab:main_results}}{table.4}{}}
\@writefile{lot}{\contentsline {table}{\numberline {V}{\ignorespaces Central architectural ablation. Values are aggregate MASE (lower is better). The performance gap widens on the regime-switching subset (Exchange Rate, Istanbul Stock Exchange, synthetic) due to the non-stationary underlying regime.}}{6}{table.5}\protected@file@percent }
\newlabel{tab:ablation}{{V}{6}{Central architectural ablation. Values are aggregate MASE (lower is better). The performance gap widens on the regime-switching subset (Exchange Rate, Istanbul Stock Exchange, synthetic) due to the non-stationary underlying regime}{table.5}{}}
